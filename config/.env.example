# ============================================================
# Environment Variables — Copy to .env and fill in values
# ============================================================
# NEVER commit .env to source control.
# Add .env to your .gitignore.
# ============================================================

# Microsoft Teams Incoming Webhook URL
# How to get this: Teams Channel → ⋯ More Options → Connectors → Incoming Webhook → Configure
TEAMS_WEBHOOK_URL=https://yourcompany.webhook.office.com/webhookb2/xxxx

# Email credentials
# For Office 365: your full email address
# For Gmail: your Gmail address + use an App Password (not your account password)
EMAIL_USERNAME=your.email@yourcompany.com
EMAIL_PASSWORD=your_app_password_here

# Override OneDrive recordings path (optional — can also be set in settings.yaml)
WATCH_PATH=C:/Users/YourName/OneDrive - YourCompany/Recordings

# Override Ollama URL (optional — default is http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# ── Feature 8: Sentiment & Morale Detection ────────────────────────────
# Single manager email that receives the confidential morale report.
# Never sent to the full team.
SENTIMENT_MANAGER_EMAIL=manager@yourcompany.com

# -- Feature 9: Draft Approval Gate -----------------------------------------
# Email address of the person who must approve the MOM draft
# before it is delivered to the team.
APPROVAL_ORGANIZER_EMAIL=organizer@yourcompany.com

# -- SQL Server Database Connection -----------------------------------------
# These override the values in config/settings.yaml under the database: section.
# For Windows Authentication (default on this machine), leave DB_USERNAME/DB_PASSWORD blank.
# For SQL Authentication: set DB_TRUSTED_CONNECTION=false and fill in DB_USERNAME/DB_PASSWORD.
DB_SERVER=ICS-LT-H3J9R73\SQLEXPRESS
DB_NAME=MeetingSystem
DB_DRIVER=ODBC Driver 17 for SQL Server
DB_TRUSTED_CONNECTION=true
DB_USERNAME=
DB_PASSWORD=
